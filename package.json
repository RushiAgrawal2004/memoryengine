{
  "name": "memory-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "build": "tsc",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:local:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-local-postgres.ps1",
    "embeddings:backfill": "tsx src/scripts/backfill-embeddings.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.2",
    "postgres": "^3.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.2"
  }
}
