DATABASE_URL=postgres://memory_engine:memory_engine@localhost:5432/memory_engine
PORT=3777
# local is deterministic lexical hashing only; use hosted for real semantic retrieval/evals.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=local
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
RERANK_PROVIDER=none
COHERE_API_KEY=
RERANK_MODEL=rerank-v3.5
CONSOLIDATE_CRON=*/30 * * * *
REFLECT_EPISODE_LIMIT=100
DECAY_DAYS=30
DECAY_FLOOR=0.2

# Cheap hosted Gemini option using Google's OpenAI-compatible API:
# EMBEDDINGS_PROVIDER=hosted
# EMBEDDINGS_API_KEY=your_gemini_api_key
# EMBEDDINGS_MODEL=gemini-embedding-2-preview
# EMBEDDINGS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_PROVIDER=hosted
# LLM_API_KEY=your_gemini_api_key
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
